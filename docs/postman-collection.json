{
  "info": {
    "name": "MagicPAI API",
    "description": "MagicPAI REST API. Post-Temporal migration.\n\nSee temporal.md Appendix X for the full OpenAPI spec.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "mpai-collection-v1"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:5000", "type": "string" },
    { "key": "sessionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base}}/health", "host": ["{{base}}"], "path": ["health"] }
          }
        },
        {
          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base}}/metrics", "host": ["{{base}}"], "path": ["metrics"] }
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create — SimpleAgent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 202', () => pm.response.to.have.status(202));",
                  "pm.test('Returns sessionId', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.sessionId).to.match(/^mpai-[a-f0-9]{32}$/);",
                  "    pm.collectionVariables.set('sessionId', body.sessionId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Print hello world\",\n  \"workflowType\": \"SimpleAgent\",\n  \"aiAssistant\": \"claude\",\n  \"model\": \"haiku\",\n  \"modelPower\": 3,\n  \"workspacePath\": \"/tmp/postman-test\",\n  \"enableGui\": false\n}"
            },
            "url": { "raw": "{{base}}/api/sessions", "host": ["{{base}}"], "path": ["api", "sessions"] }
          }
        },
        {
          "name": "Create — FullOrchestrate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Build a TODO web app\",\n  \"workflowType\": \"FullOrchestrate\",\n  \"aiAssistant\": \"claude\",\n  \"model\": \"auto\",\n  \"modelPower\": 0,\n  \"workspacePath\": \"/workspaces/todo-app\",\n  \"enableGui\": true\n}"
            },
            "url": { "raw": "{{base}}/api/sessions", "host": ["{{base}}"], "path": ["api", "sessions"] }
          }
        },
        {
          "name": "List recent sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base}}/api/sessions?take=50",
              "host": ["{{base}}"],
              "path": ["api", "sessions"],
              "query": [{ "key": "take", "value": "50" }]
            }
          }
        },
        {
          "name": "Get session status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base}}/api/sessions/{{sessionId}}",
              "host": ["{{base}}"],
              "path": ["api", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "Cancel session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base}}/api/sessions/{{sessionId}}",
              "host": ["{{base}}"],
              "path": ["api", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "Terminate session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"reason\": \"Manual terminate via Postman\" }"
            },
            "url": {
              "raw": "{{base}}/api/sessions/{{sessionId}}/terminate",
              "host": ["{{base}}"],
              "path": ["api", "sessions", "{{sessionId}}", "terminate"]
            }
          }
        }
      ]
    },
    {
      "name": "Workflows",
      "item": [
        {
          "name": "List workflow types",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base}}/api/workflows", "host": ["{{base}}"], "path": ["api", "workflows"] }
          }
        },
        {
          "name": "Get Temporal UI URL for session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base}}/api/workflows/{{sessionId}}/ui-url",
              "host": ["{{base}}"],
              "path": ["api", "workflows", "{{sessionId}}", "ui-url"]
            }
          }
        }
      ]
    },
    {
      "name": "Config",
      "item": [
        {
          "name": "Temporal config",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base}}/api/config/temporal", "host": ["{{base}}"], "path": ["api", "config", "temporal"] }
          }
        }
      ]
    }
  ]
}
