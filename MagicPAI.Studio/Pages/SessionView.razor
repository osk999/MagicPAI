@* MagicPAI.Studio/Pages/SessionView.razor — Temporal migration §10.9. *@
@page "/sessions/{Id}"
@inject SessionApiClient SessionClient
@inject SessionHubClient Hub
@inject TemporalUiUrlBuilder UrlBuilder
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Session @(Id.Length > 8 ? Id[..8] : Id)</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Session @(Id.Length > 12 ? Id[..12] + "…" : Id)</MudText>
        <SessionStatusBadge Status="@_status" />
        <PipelineStageChip Stage="@_pipelineStage" />
        <MudSpacer />
        <MudButton OnClick="Cancel"
                   Color="Color.Warning"
                   Disabled="@(!_isRunning)"
                   StartIcon="@Icons.Material.Filled.Cancel">
            Cancel
        </MudButton>
        <MudButton OnClick="OpenTemporalUi"
                   Color="Color.Default"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.OpenInNew">
            View in Temporal UI
        </MudButton>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="8">
            <CliOutputStream Lines="_lines" IsActive="@_isRunning" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudStack Spacing="3">
                <CostDisplay SessionId="@Id" />
                <ContainerStatusPanel SessionId="@Id" />
                @if (_gateAwaiting is not null)
                {
                    <GateApprovalPanel SessionId="@Id"
                                       GateName="@_gateAwaiting.GateName"
                                       PromptForHuman="@_gateAwaiting.PromptForHuman"
                                       OnApprove="HandleApprove"
                                       OnReject="HandleReject" />
                }
                <VerificationResultsTable SessionId="@Id" />
            </MudStack>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    [Parameter] public string Id { get; set; } = "";

    private readonly List<string> _lines = new();
    private string _status = "Running";
    private string _pipelineStage = "initializing";
    private GateAwaitingPayload? _gateAwaiting;
    private bool _joined;

    private bool _isRunning => _status is "Running" or "Pending" or not ("Completed" or "Failed" or "Cancelled" or "Terminated");

    protected override async Task OnInitializedAsync()
    {
        Hub.OutputChunk += OnOutputChunk;
        Hub.StageChanged += OnStageChanged;
        Hub.GateAwaiting += OnGateAwaiting;
        Hub.SessionCompleted += OnSessionCompleted;
        Hub.SessionFailed += OnSessionFailed;
        Hub.SessionCancelled += OnSessionCancelled;

        await UrlBuilder.InitializeAsync();

        var desc = await SessionClient.GetAsync(Id);
        if (desc is not null)
        {
            _status = NormalizeStatus(desc.Status);
        }

        try
        {
            await Hub.JoinSessionAsync(Id);
            _joined = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Unable to join live stream: {ex.Message}", Severity.Warning);
        }
    }

    private void OnOutputChunk(string line)
    {
        _lines.Add(line);
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnStageChanged(string stage)
    {
        _pipelineStage = stage;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnGateAwaiting(GateAwaitingPayload payload)
    {
        if (payload.SessionId != Id) return;
        _gateAwaiting = payload;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnSessionCompleted(SessionCompletedPayload payload)
    {
        if (payload.SessionId != Id) return;
        _status = "Completed";
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnSessionFailed(SessionFailedPayload payload)
    {
        if (payload.SessionId != Id) return;
        _status = "Failed";
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnSessionCancelled(SessionCancelledPayload payload)
    {
        if (payload.SessionId != Id) return;
        _status = "Cancelled";
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task Cancel()
    {
        var ok = await SessionClient.CancelAsync(Id);
        if (ok)
            Snackbar.Add("Cancel requested.", Severity.Info);
        else
            Snackbar.Add("Cancel request failed.", Severity.Error);
    }

    private void OpenTemporalUi() =>
        Nav.NavigateTo(UrlBuilder.ForSession(Id), forceLoad: true);

    private Task HandleApprove(string comment)
    {
        _gateAwaiting = null;
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleReject(string reason)
    {
        _gateAwaiting = null;
        return InvokeAsync(StateHasChanged);
    }

    private static string NormalizeStatus(string raw) =>
        raw?.ToLowerInvariant() switch
        {
            "running"           => "Running",
            "completed"         => "Completed",
            "failed"            => "Failed",
            "canceled"          => "Cancelled",
            "cancelled"         => "Cancelled",
            "terminated"        => "Terminated",
            "continuedasnew"    => "Running",
            "timedout"          => "Failed",
            _                   => raw ?? "Unknown"
        };

    public async ValueTask DisposeAsync()
    {
        Hub.OutputChunk -= OnOutputChunk;
        Hub.StageChanged -= OnStageChanged;
        Hub.GateAwaiting -= OnGateAwaiting;
        Hub.SessionCompleted -= OnSessionCompleted;
        Hub.SessionFailed -= OnSessionFailed;
        Hub.SessionCancelled -= OnSessionCancelled;
        if (_joined)
            await Hub.LeaveSessionAsync(Id);
    }
}
