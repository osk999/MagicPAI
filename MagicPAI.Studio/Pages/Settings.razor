@* MagicPAI.Studio/Pages/Settings.razor — Temporal migration §S.9. *@
@page "/settings"
@inject HttpClient Http
@inject TemporalUiUrlBuilder UrlBuilder

<PageTitle>Settings</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

    <MudCard Class="mt-4">
        <MudCardContent>
            <MudText Typo="Typo.subtitle1">Backend</MudText>
            <MudText Typo="Typo.body2">Server: @_backendUrl</MudText>
            <MudText Typo="Typo.body2">Temporal UI: @_temporalUi</MudText>
            <MudText Typo="Typo.body2">Temporal namespace: @_temporalNs</MudText>
            <MudButton Color="Color.Secondary"
                       Href="@_temporalUi"
                       Target="_blank"
                       Class="mt-2"
                       StartIcon="@Icons.Material.Filled.OpenInNew"
                       Disabled="@string.IsNullOrEmpty(_temporalUi)">
                Open Temporal UI
            </MudButton>
        </MudCardContent>
    </MudCard>

    <MudCard Class="mt-4">
        <MudCardContent>
            <MudText Typo="Typo.subtitle1">Credentials</MudText>
            @if (_authOk)
            {
                <MudAlert Severity="Severity.Success" Dense="true">Claude auth OK</MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Warning" Dense="true">Claude auth status unknown</MudAlert>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private string _backendUrl = "";
    private string _temporalUi = "";
    private string _temporalNs = "";
    private bool _authOk = true;

    protected override async Task OnInitializedAsync()
    {
        _backendUrl = Http.BaseAddress?.ToString() ?? "";
        await UrlBuilder.InitializeAsync();
        _temporalUi = UrlBuilder.ForNamespace();
        _temporalNs = UrlBuilder.Namespace;
    }
}
