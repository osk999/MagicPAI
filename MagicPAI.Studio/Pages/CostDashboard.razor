@* MagicPAI.Studio/Pages/CostDashboard.razor — rewritten for Temporal. *@
@page "/costs"
@inject SessionApiClient SessionClient
@inject SessionHubClient Hub
@implements IDisposable

<PageTitle>Cost analytics</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Cost analytics</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Total spend (7d)</MudText>
            <MudText Typo="Typo.h4">@($"${_totalCost:F4}")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Sessions</MudText>
            <MudText Typo="Typo.h4">@_sessions.Count</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Average cost / session</MudText>
            <MudText Typo="Typo.h4">@($"${_avgCost:F4}")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Live increments</MudText>
            <MudText Typo="Typo.h4">@_liveCount</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-6" Elevation="2">
    <MudText Typo="Typo.h5" Class="mb-3">Cost by session</MudText>
    <MudTable Items="@_sessions.OrderByDescending(s => s.StartTime)" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Session</MudTh>
            <MudTh>Workflow</MudTh>
            <MudTh>Assistant</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Cost (USD)</MudTh>
            <MudTh>Started</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudLink Href="@($"/sessions/{context.SessionId}")">
                    @(context.SessionId.Length > 12 ? context.SessionId[..12] + "…" : context.SessionId)
                </MudLink>
            </MudTd>
            <MudTd>@context.WorkflowType</MudTd>
            <MudTd>@context.AiAssistant</MudTd>
            <MudTd><SessionStatusBadge Status="@context.Status" /></MudTd>
            <MudTd>@($"${context.TotalCostUsd:F4}")</MudTd>
            <MudTd>@context.StartTime.ToLocalTime().ToString("g")</MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<SessionSummary> _sessions = new();
    private decimal _totalCost;
    private decimal _avgCost;
    private int _liveCount;

    protected override async Task OnInitializedAsync()
    {
        Hub.CostUpdate += OnCostUpdate;
        _sessions = await SessionClient.ListAsync(take: 100);
        _totalCost = _sessions.Sum(s => s.TotalCostUsd);
        _avgCost = _sessions.Count == 0 ? 0 : _totalCost / _sessions.Count;
    }

    private void OnCostUpdate(CostEntry entry)
    {
        _liveCount++;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Hub.CostUpdate -= OnCostUpdate;
    }
}
