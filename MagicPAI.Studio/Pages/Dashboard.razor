@* MagicPAI.Studio/Pages/Dashboard.razor — rewritten for Temporal. *@
@page "/dashboard"
@inject SessionApiClient SessionClient
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Total sessions (7d)</MudText>
            <MudText Typo="Typo.h4">@_sessions.Count</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Running</MudText>
            <MudText Typo="Typo.h4">@_running</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Completed</MudText>
            <MudText Typo="Typo.h4">@_completed</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Total spend</MudText>
            <MudText Typo="Typo.h4">@($"${_totalCost:F2}")</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-6" Elevation="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h5">Recent sessions</MudText>
        <MudSpacer />
        <MudButton Href="/sessions" Variant="Variant.Outlined">View all</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Href="/">New session</MudButton>
    </MudStack>

    <MudTable Items="@_sessions.Take(10)" Loading="@_loading" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Id</MudTh>
            <MudTh>Workflow</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Started</MudTh>
            <MudTh>Cost</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudLink Href="@($"/sessions/{context.SessionId}")">@(context.SessionId.Length > 12 ? context.SessionId[..12] + "…" : context.SessionId)</MudLink></MudTd>
            <MudTd>@context.WorkflowType</MudTd>
            <MudTd><SessionStatusBadge Status="@context.Status" /></MudTd>
            <MudTd>@context.StartTime.ToLocalTime().ToString("g")</MudTd>
            <MudTd>@($"${context.TotalCostUsd:F4}")</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No sessions in the last 7 days.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<SessionSummary> _sessions = new();
    private bool _loading = true;
    private int _running;
    private int _completed;
    private decimal _totalCost;

    protected override async Task OnInitializedAsync()
    {
        _sessions = await SessionClient.ListAsync(take: 100);
        _running = _sessions.Count(s => string.Equals(s.Status, "Running", StringComparison.OrdinalIgnoreCase));
        _completed = _sessions.Count(s => string.Equals(s.Status, "Completed", StringComparison.OrdinalIgnoreCase));
        _totalCost = _sessions.Sum(s => s.TotalCostUsd);
        _loading = false;
    }
}
