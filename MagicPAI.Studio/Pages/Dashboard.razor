@page "/magic/dashboard"
@using MagicPAI.Shared.Models
@using MagicPAI.Studio.Services
@using MagicPAI.Studio.Components
@inject SessionHubClient Hub
@inject SessionApiClient Api
@inject NavigationManager Navigation

<PageTitle>MagicPAI Dashboard</PageTitle>

<div class="dashboard">
    <h2>MagicPAI Dashboard</h2>

    <div class="quick-start card">
        <h3>Start a New Session</h3>
        <textarea @bind="prompt" @bind:event="oninput" placeholder="Describe your task..." rows="3" class="form-input" />

        <div class="form-group">
            <label>Workspace Path</label>
            <div class="path-browser">
                <input @bind="workspacePath" @bind:event="oninput" placeholder="/path/to/project" class="form-input path-input" />
                <button @onclick="ToggleBrowser" class="btn btn-secondary" type="button" title="Browse folders">
                    @(showBrowser ? "Close" : "Browse...")
                </button>
            </div>
            @if (showBrowser)
            {
                <div class="browser-panel">
                    <div class="browser-header">
                        <span class="browser-path" title="@browserCurrentPath">@(string.IsNullOrEmpty(browserCurrentPath) ? "Drives" : browserCurrentPath)</span>
                        @if (!string.IsNullOrEmpty(browserParentPath))
                        {
                            <button @onclick="NavigateUp" class="btn btn-sm" type="button">..</button>
                        }
                        @if (!string.IsNullOrEmpty(browserCurrentPath))
                        {
                            <button @onclick="SelectCurrentPath" class="btn btn-primary btn-sm" type="button">Select this folder</button>
                        }
                    </div>
                    @if (browserLoading)
                    {
                        <p class="browser-loading">Loading...</p>
                    }
                    else if (browserDirs.Count == 0)
                    {
                        <p class="browser-empty">No subdirectories</p>
                    }
                    else
                    {
                        <div class="browser-list">
                            @foreach (var dir in browserDirs)
                            {
                                <div class="browser-item" @onclick="() => NavigateInto(dir.FullPath)">
                                    <span class="folder-icon">&#128193;</span> @dir.Name
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="controls">
            <AgentSelector @bind-Value="selectedAgent" />
            <div class="form-group workflow-group">
                <label>Workflow</label>
                <select @bind="selectedWorkflow" class="form-input workflow-selector">
                    @foreach (var wf in workflows)
                    {
                        <option value="@wf.Id">@wf.DisplayName</option>
                    }
                </select>
            </div>
            <button @onclick="StartSession" disabled="@isStarting" class="btn btn-primary">
                @(isStarting ? "Starting..." : "Start Session")
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="error-text">@errorMessage</p>
        }
    </div>

    <div class="session-list">
        <h3>Active Sessions</h3>
        @if (sessions.Count == 0)
        {
            <p class="empty-state">No sessions yet. Start one above.</p>
        }
        else
        {
            @foreach (var session in sessions)
            {
                <div class="session-card @session.State.ToLowerInvariant()"
                     @onclick="() => NavigateToSession(session.Id)">
                    <span class="status-badge">@session.State</span>
                    <span class="session-id">@(session.Id.Length > 8 ? session.Id[..8] : session.Id)...</span>
                    <span class="session-agent">@session.Agent</span>
                    <span class="session-cost">$@session.TotalCostUsd.ToString("F4")</span>
                    <span class="session-time">@session.CreatedAt.ToString("HH:mm:ss")</span>
                </div>
            }
        }
    </div>
</div>

@implements IDisposable

@code {
    private string prompt = "";
    private string selectedAgent = "claude";
    private string selectedWorkflow = "full-orchestrate";
    private string workspacePath = "";
    private bool isStarting;
    private string errorMessage = "";
    private List<SessionInfo> sessions = new();
    private List<WorkflowOption> workflows = new();

    // Browser state
    private bool showBrowser;
    private bool browserLoading;
    private string browserCurrentPath = "";
    private string? browserParentPath;
    private List<DirectoryEntry> browserDirs = new();

    protected override async Task OnInitializedAsync()
    {
        Hub.OnSessionStateChanged += OnStateChanged;
        try
        {
            await Hub.ConnectAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }

        var sessionsTask = Api.ListSessionsAsync();
        var workflowsTask = Api.ListWorkflowsAsync();
        await Task.WhenAll(sessionsTask, workflowsTask);

        sessions = sessionsTask.Result;
        workflows = workflowsTask.Result;

        if (workflows.Count == 0)
        {
            // Fallback if server hasn't loaded yet
            workflows = [new WorkflowOption("full-orchestrate", "Full Orchestrator", true)];
        }
    }

    private async Task ToggleBrowser()
    {
        showBrowser = !showBrowser;
        if (showBrowser)
        {
            // Start browsing from the current workspace path, or from root
            var startPath = string.IsNullOrWhiteSpace(workspacePath) ? null : workspacePath;
            await LoadDirectory(startPath);
        }
    }

    private async Task LoadDirectory(string? path)
    {
        browserLoading = true;
        StateHasChanged();

        var result = await Api.BrowseAsync(path);
        browserCurrentPath = result.CurrentPath;
        browserParentPath = result.ParentPath;
        browserDirs = result.Directories;

        browserLoading = false;
        StateHasChanged();
    }

    private async Task NavigateInto(string fullPath) => await LoadDirectory(fullPath);

    private async Task NavigateUp()
    {
        if (!string.IsNullOrEmpty(browserParentPath))
            await LoadDirectory(browserParentPath);
        else
            await LoadDirectory(null);
    }

    private void SelectCurrentPath()
    {
        workspacePath = browserCurrentPath;
        showBrowser = false;
    }

    private async Task StartSession()
    {
        if (string.IsNullOrWhiteSpace(prompt))
            return;

        isStarting = true;
        errorMessage = "";
        try
        {
            await Hub.ConnectAsync();
            var sessionId = await Api.CreateSessionAsync(
                prompt, workspacePath, selectedAgent,
                workflowName: selectedWorkflow);
            NavigateToSession(sessionId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isStarting = false;
        }
    }

    private void OnStateChanged(SessionStateEvent e)
    {
        var session = sessions.FirstOrDefault(s => s.Id == e.SessionId);
        if (session is not null)
            session.State = e.State;

        InvokeAsync(StateHasChanged);
    }

    private void NavigateToSession(string id) =>
        Navigation.NavigateTo($"magic/sessions/{id}");

    public void Dispose()
    {
        Hub.OnSessionStateChanged -= OnStateChanged;
    }
}
