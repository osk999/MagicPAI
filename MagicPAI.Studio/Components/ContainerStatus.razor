<div class="container-status">
    @if (string.IsNullOrEmpty(ContainerId))
    {
        <span class="status-indicator idle">No Container</span>
    }
    else
    {
        <span class="status-indicator running">Container: @(ContainerId.Length > 12 ? ContainerId[..12] : ContainerId)</span>
        @if (!string.IsNullOrEmpty(GuiUrl))
        {
            <a href="@GuiUrl" target="_blank" class="vnc-link" title="Open noVNC desktop viewer">
                noVNC Desktop
            </a>
        }
    }
</div>

@code {
    [Parameter] public string ContainerId { get; set; } = "";
    [Parameter] public string? GuiUrl { get; set; }
}
