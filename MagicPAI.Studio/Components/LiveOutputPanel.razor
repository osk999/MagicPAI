@using System.Text
@using MagicPAI.Studio.Services
@inject WorkflowInstanceLiveUpdater LiveUpdater
@inject IJSRuntime JS
@implements IDisposable

<div class="live-output-panel">
    <div class="live-output-header">
        <span>Live Output</span>
        <div class="live-output-controls">
            <select class="form-input live-output-filter" @bind="selectedActivity">
                <option value="">All Activities</option>
                @foreach (var name in _knownActivities)
                {
                    <option value="@name">@name</option>
                }
            </select>
            <button @onclick="CopyToClipboard" class="btn btn-sm" title="Copy to clipboard">Copy</button>
            <button @onclick="Clear" class="btn btn-sm" title="Clear output">Clear</button>
        </div>
    </div>
    <pre class="live-output-content" @ref="_preElement">@GetFilteredOutput()</pre>
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private ElementReference _preElement;
    private readonly List<OutputEntry> _entries = new();
    private readonly HashSet<string> _knownActivities = new();
    private string selectedActivity = "";
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        LiveUpdater.OnOutputChunkReceived += HandleOutputChunk;
        LiveUpdater.OnActivityStatusChanged += HandleActivityStatus;
        LiveUpdater.OnErrorReceived += HandleError;

        try
        {
            await LiveUpdater.StartAsync();
            await LiveUpdater.SubscribeToSession(SessionId);
        }
        catch
        {
            // Hub may not be available during development
        }
    }

    private void HandleOutputChunk(string sessionId, string text)
    {
        if (sessionId != SessionId) return;
        _entries.Add(new OutputEntry(DateTime.UtcNow, text, null, OutputKind.Info));
        InvokeAsync(StateHasChanged);
    }

    private void HandleActivityStatus(string sessionId, string activityName, string status)
    {
        if (sessionId != SessionId) return;
        _knownActivities.Add(activityName);

        var kind = status.Equals("failed", StringComparison.OrdinalIgnoreCase)
            ? OutputKind.Error
            : status.Equals("completed", StringComparison.OrdinalIgnoreCase) || status.Equals("done", StringComparison.OrdinalIgnoreCase)
                ? OutputKind.Success
                : OutputKind.Info;

        _entries.Add(new OutputEntry(DateTime.UtcNow, $"[{activityName}] {status}", activityName, kind));
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string sessionId, string message)
    {
        if (sessionId != SessionId) return;
        _entries.Add(new OutputEntry(DateTime.UtcNow, message, null, OutputKind.Error));
        InvokeAsync(StateHasChanged);
    }

    private string GetFilteredOutput()
    {
        var sb = new StringBuilder();
        foreach (var entry in _entries)
        {
            if (!string.IsNullOrEmpty(selectedActivity) && entry.ActivityName != selectedActivity)
                continue;

            var timestamp = entry.Timestamp.ToString("HH:mm:ss");
            sb.AppendLine($"[{timestamp}] {entry.Text}");
        }
        return sb.ToString();
    }

    private async Task CopyToClipboard()
    {
        var text = GetFilteredOutput();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private void Clear()
    {
        _entries.Clear();
        _knownActivities.Clear();
        StateHasChanged();
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        LiveUpdater.OnOutputChunkReceived -= HandleOutputChunk;
        LiveUpdater.OnActivityStatusChanged -= HandleActivityStatus;
        LiveUpdater.OnErrorReceived -= HandleError;
        _ = LiveUpdater.UnsubscribeFromSession(SessionId);
    }

    private enum OutputKind { Info, Success, Error }
    private record OutputEntry(DateTime Timestamp, string Text, string? ActivityName, OutputKind Kind);
}
