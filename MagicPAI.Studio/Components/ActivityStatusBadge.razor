@* Small component showing activity execution status with icon and color *@

<span class="activity-status-badge @CssClass">
    <span class="activity-badge-icon">@Icon</span>
    <span class="activity-badge-label">@Label</span>
</span>

@code {
    /// <summary>Activity execution status: Running, Completed, Faulted, Pending.</summary>
    [Parameter] public string Status { get; set; } = "Pending";

    /// <summary>Optional label text. Defaults to Status if not set.</summary>
    [Parameter] public string? Label { get; set; }

    private string DisplayLabel => Label ?? Status;

    private string CssClass => NormalizedStatus switch
    {
        "running" => "badge-running",
        "completed" or "done" => "badge-completed",
        "faulted" or "failed" => "badge-faulted",
        _ => "badge-pending"
    };

    private string Icon => NormalizedStatus switch
    {
        "running" => "~",      // spinning indicator placeholder
        "completed" or "done" => "+",
        "faulted" or "failed" => "x",
        _ => "o"               // gray circle placeholder
    };

    private string NormalizedStatus => Status.ToLowerInvariant();
}
