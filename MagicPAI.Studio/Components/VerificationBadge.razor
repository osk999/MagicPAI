<div class="verification-badge @(Passed ? "passed" : "failed")">
    <span class="badge-icon">@(Passed ? "PASS" : "FAIL")</span>
    <span class="badge-name">@GateName</span>
    @if (!string.IsNullOrEmpty(Output))
    {
        <div class="badge-output">@Output</div>
    }
    @if (Issues.Length > 0)
    {
        <ul class="badge-issues">
            @foreach (var issue in Issues)
            {
                <li>@issue</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public string GateName { get; set; } = "";
    [Parameter] public bool Passed { get; set; }
    [Parameter] public string Output { get; set; } = "";
    [Parameter] public string[] Issues { get; set; } = [];
}
