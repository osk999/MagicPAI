@using MagicPAI.Studio.Models

<div class="dag-view">
    <h4>Workflow Progress</h4>
    @if (Activities.Count == 0)
    {
        <p class="empty-state">No activity data yet.</p>
    }
    else
    {
        <div class="dag-list">
            @foreach (var activity in Activities)
            {
                <div class="dag-node @activity.Status.ToLowerInvariant()">
                    <span class="dag-status-icon">@GetStatusIcon(activity.Status)</span>
                    <span class="dag-name">@activity.Name</span>
                    <span class="dag-status">@activity.Status</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<ActivityStateDto> Activities { get; set; } = new();

    private static string GetStatusIcon(string status) => status.ToLowerInvariant() switch
    {
        "running" => "[*]",
        "completed" or "done" => "[+]",
        "failed" => "[x]",
        "pending" => "[ ]",
        _ => "[?]"
    };
}
