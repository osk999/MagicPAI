<div class="dag-view">
    <h4>Workflow Progress</h4>
    @if (Activities.Count == 0)
    {
        <p class="empty-state">No activity data yet.</p>
    }
    else
    {
        <div class="dag-list">
            @foreach (var (name, status) in Activities)
            {
                <div class="dag-node @status.ToLowerInvariant()">
                    <span class="dag-status-icon">@GetStatusIcon(status)</span>
                    <span class="dag-name">@name</span>
                    <span class="dag-status">@status</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<(string Name, string Status)> Activities { get; set; } = new();

    private static string GetStatusIcon(string status) => status.ToLowerInvariant() switch
    {
        "running" => "[*]",
        "completed" or "done" => "[+]",
        "failed" => "[x]",
        "pending" => "[ ]",
        _ => "[?]"
    };
}
