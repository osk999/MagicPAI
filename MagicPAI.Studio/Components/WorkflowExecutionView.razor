@using MagicPAI.Studio.Services
@inject WorkflowInstanceLiveUpdater LiveUpdater
@implements IDisposable

<div class="workflow-execution-view">
    @* Left: workflow info *@
    <div class="wfv-info">
        <div class="wfv-header">
            <h3>@WorkflowName</h3>
            <ActivityStatusBadge Status="@_sessionState" />
        </div>

        <div class="wfv-meta">
            @if (_startedAt is not null)
            {
                <span class="wfv-duration">Duration: @GetDuration()</span>
            }
        </div>

        @if (_totalSteps > 0)
        {
            <div class="wfv-progress">
                <div class="wfv-progress-bar">
                    <div class="wfv-progress-fill" style="width: @ProgressPercent%"></div>
                </div>
                <span class="wfv-progress-label">@_completedSteps / @_totalSteps steps</span>
            </div>
        }

        @* Activity execution timeline *@
        <div class="wfv-timeline">
            <h4>Activity Timeline</h4>
            @if (_activityStatuses.Count == 0)
            {
                <p class="empty-state">Waiting for activity events...</p>
            }
            else
            {
                @foreach (var kvp in _activityStatuses)
                {
                    <div class="wfv-timeline-entry">
                        <ActivityStatusBadge Status="@kvp.Value" Label="@kvp.Key" />
                    </div>
                }
            }
        </div>
    </div>

    @* Right: live output *@
    <div class="wfv-output">
        <LiveOutputPanel SessionId="@SessionId" />
    </div>
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";
    [Parameter] public string WorkflowName { get; set; } = "Workflow";

    private string _sessionState = "Pending";
    private int _completedSteps;
    private int _totalSteps;
    private DateTime? _startedAt;
    private readonly Dictionary<string, string> _activityStatuses = new();
    private bool _disposed;

    private int ProgressPercent => _totalSteps > 0 ? (int)((double)_completedSteps / _totalSteps * 100) : 0;

    protected override async Task OnInitializedAsync()
    {
        LiveUpdater.OnActivityStatusChanged += HandleActivityStatus;
        LiveUpdater.OnWorkflowProgressUpdated += HandleProgress;
        LiveUpdater.OnSessionStateChanged += HandleStateChanged;

        try
        {
            await LiveUpdater.StartAsync();
            await LiveUpdater.SubscribeToSession(SessionId);
        }
        catch
        {
            // Hub may not be available
        }
    }

    private void HandleActivityStatus(string sessionId, string activityName, string status)
    {
        if (sessionId != SessionId) return;
        _activityStatuses[activityName] = status;

        if (_startedAt is null && status.Equals("running", StringComparison.OrdinalIgnoreCase))
        {
            _startedAt = DateTime.UtcNow;
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleProgress(string sessionId, int completed, int total)
    {
        if (sessionId != SessionId) return;
        _completedSteps = completed;
        _totalSteps = total;
        InvokeAsync(StateHasChanged);
    }

    private void HandleStateChanged(string sessionId, string state)
    {
        if (sessionId != SessionId) return;
        _sessionState = state;
        InvokeAsync(StateHasChanged);
    }

    private string GetDuration()
    {
        if (_startedAt is null) return "--";
        var elapsed = DateTime.UtcNow - _startedAt.Value;
        return elapsed.TotalMinutes >= 1
            ? $"{(int)elapsed.TotalMinutes}m {elapsed.Seconds}s"
            : $"{elapsed.Seconds}s";
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        LiveUpdater.OnActivityStatusChanged -= HandleActivityStatus;
        LiveUpdater.OnWorkflowProgressUpdated -= HandleProgress;
        LiveUpdater.OnSessionStateChanged -= HandleStateChanged;
        _ = LiveUpdater.UnsubscribeFromSession(SessionId);
    }
}
