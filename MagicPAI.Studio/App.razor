@* MagicPAI.Studio/App.razor — Temporal migration §10.6 minimal root. *@
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MagicPAI.Studio.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MagicPAI.Studio.Layout.MainLayout)">
            <MudText Typo="Typo.h4" Class="pa-6">404 — Page not found</MudText>
        </LayoutView>
    </NotFound>
</Router>
