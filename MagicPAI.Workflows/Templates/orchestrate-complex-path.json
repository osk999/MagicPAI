{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "OrchestrateComplexPathWorkflow",
  "name": "Orchestrate Complex Path",
  "description": "Multi-agent decomposition: architect, model routing, parallel workers, verify and repair",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" },
    { "name": "Agent", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "sonnet" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "orchestrate-complex-path-flow",
    "start": "architect-decompose",
    "activities": [
      {
        "type": "MagicPAI.ArchitectActivity",
        "id": "architect-decompose",
        "name": "Architect Decompose"
      },
      {
        "type": "MagicPAI.ModelRouterActivity",
        "id": "model-router",
        "name": "Model Router"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "complex-worker",
        "name": "Complex Worker"
      },
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "complex-verify",
        "name": "Verify"
      },
      {
        "type": "MagicPAI.RepairActivity",
        "id": "complex-repair",
        "name": "Repair"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "complex-repair-agent",
        "name": "Repair Agent"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "merge-results",
        "name": "Merge Results"
      }
    ],
    "connections": [
      { "source": { "activity": "architect-decompose", "port": "Done" }, "target": { "activity": "model-router" } },
      { "source": { "activity": "model-router", "port": "Done" }, "target": { "activity": "complex-worker" } },
      { "source": { "activity": "complex-worker", "port": "Done" }, "target": { "activity": "complex-verify" } },
      { "source": { "activity": "complex-worker", "port": "Failed" }, "target": { "activity": "merge-results" } },
      { "source": { "activity": "complex-verify", "port": "Passed" }, "target": { "activity": "merge-results" } },
      { "source": { "activity": "complex-verify", "port": "Inconclusive" }, "target": { "activity": "merge-results" } },
      { "source": { "activity": "complex-verify", "port": "Failed" }, "target": { "activity": "complex-repair" } },
      { "source": { "activity": "complex-repair", "port": "Done" }, "target": { "activity": "complex-repair-agent" } },
      { "source": { "activity": "complex-repair-agent", "port": "Done" }, "target": { "activity": "complex-verify" } },
      { "source": { "activity": "complex-repair-agent", "port": "Failed" }, "target": { "activity": "merge-results" } }
    ]
  }
}
