  "text": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\" />\n    <title>MagicPAI Studio</title>\n    <base href=\"/\" />\n\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/_content/Elsa.Studio.Shell/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/_content/Elsa.Studio.Shell/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/_content/Elsa.Studio.Shell/favicon-16x16.png\">\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap\" rel=\"stylesheet\" />\n    <link href=\"https://fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n    <link href=\"/_content/MudBlazor/MudBlazor.min.css\" rel=\"stylesheet\" />\n    <link href=\"/_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.css\" rel=\"stylesheet\" />\n    <link href=\"/_content/Radzen.Blazor/css/material-base.css\" rel=\"stylesheet\">\n    <link href=\"/_content/Elsa.Studio.Shell/css/shell.css\" rel=\"stylesheet\">\n</head>\n<body>\n    <div id=\"app\">\n        <div style=\"display:flex;flex-direction:column;justify-content:center;align-items:center;height:100vh;background:#0f172a;color:#f1f5f9;font-family:Inter,system-ui,sans-serif;gap:1rem;\">\n            <div style=\"width:40px;height:40px;border:3px solid #334155;border-top-color:#6366f1;border-radius:50%;animation:spin .8s linear infinite;\"></div>\n            <p style=\"color:#94a3b8;font-size:.875rem;\">Loading MagicPAI Studio&hellip;</p>\n            <style>@keyframes spin{to{transform:rotate(360deg)}}</style>\n        </div>\n    </div>\n\n    <div id=\"blazor-error-ui\" style=\"display:none;\">\n        An unhandled error has occurred.\n        <a href=\"\" class=\"reload\">Reload</a>\n        <a class=\"dismiss\" style=\"cursor:pointer;\">Dismiss</a>\n    </div>\n\n    <!-- Monaco AMD loader (must load before editor.main) -->\n    <script src=\"/_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js\"></script>\n    <script>require.config({ paths: { 'vs': '/_content/BlazorMonaco/lib/monaco-editor/min/vs' }});</script>\n\n    <script src=\"/_content/MudBlazor/MudBlazor.min.js\"></script>\n    <script src=\"/_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.js\"></script>\n    <script src=\"/_content/Radzen.Blazor/Radzen.Blazor.js\"></script>\n\n    <!-- Blazor: delay start until Monaco is fully loaded -->\n    <script src=\"_framework/blazor.webassembly.js\" autostart=\"false\"></script>\n    <script>\n        (function () {\n            require(['vs/editor/editor.main'], function (m) {\n                // Monaco 0.50+ exports API nested under m.m instead of setting window.monaco\n                if (typeof window.monaco === 'undefined' && m && m.m) {\n                    window.monaco = m.m;\n                }\n                // Load BlazorMonaco interop AFTER monaco global is set\n                var script = document.createElement('script');\n                script.src = '/_content/BlazorMonaco/jsInterop.js';\n                script.onload = function () {\n                    Blazor.start();\n                };\n                document.head.appendChild(script);\n            });\n        })();\n    </script>\n</body>\n</html>\n"
