# MagicPAI environment variable reference
# Copy to .env.local for local dev; never commit .env.local.
# Production secrets are injected via orchestrator (k8s secrets, Docker secrets).
#
# See temporal.md Appendix KK for the full secret inventory.

# =======================================================================
# MagicPAI server
# =======================================================================
ASPNETCORE_ENVIRONMENT=Development
# ConnectionStrings__MagicPai=Host=db;Database=magicpai;Username=magicpai;Password=magicpai

# Docker enforcement (see temporal.md §11)
MagicPAI__ExecutionBackend=docker
MagicPAI__UseWorkerContainers=true
MagicPAI__RequireContainerizedAgentExecution=true
MagicPAI__WorkerImage=magicpai-env:latest
MagicPAI__WorkspacePath=/workspaces
MagicPAI__ContainerWorkDir=/workspace
MagicPAI__DefaultAgent=claude
MagicPAI__ComplexityThreshold=7

# =======================================================================
# Temporal
# =======================================================================
Temporal__Host=localhost:7233
Temporal__Namespace=magicpai
Temporal__TaskQueue=magicpai-main
Temporal__UiBaseUrl=http://localhost:8233

# mTLS (prod only)
# Temporal__Tls__Enabled=true
# Temporal__Tls__ClientCertPath=/etc/certs/client.crt
# Temporal__Tls__ClientKeyPath=/etc/certs/client.key
# Temporal__Tls__ServerRootCaPath=/etc/certs/ca.crt
# Temporal__ApiKey=<secret>

# Payload codec (optional, for compliance)
# Temporal__DataConverter__EncryptionEnabled=false
# Temporal__DataConverter__EncryptionKeyBase64=<secret>

# =======================================================================
# OpenTelemetry
# =======================================================================
# OTel__Endpoint=http://localhost:4317
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =======================================================================
# Build
# =======================================================================
DOTNET_CLI_TELEMETRY_OPTOUT=1
# MPAI_BUILD_ID=dev

# =======================================================================
# Claude CLI (mounted from host ~/.claude)
# =======================================================================
# No env vars required; credentials live in ~/.claude.json + ~/.claude/.credentials.json
# Mounted into containers by DockerContainerManager.BuildCredentialBinds().
