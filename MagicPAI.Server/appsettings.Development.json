{
  "ConnectionStrings": {
    "MagicPai": "Data Source=magicpai.db"
  },
  "MagicPAI": {
    "UseDocker": true,
    "RequireContainerizedAgentExecution": true,
    "EnableContainerPool": false,
    "EnableWorktreeIsolation": false,
    "MountDockerSocket": true,
    "WorkerImage": "magicpai-env:latest",
    "DefaultMemoryLimitMb": 4096,
    "ContainerTimeoutMinutes": 30,
    "AgentTimeoutMinutes": 30,
    "EnableContainerGui": true,
    "GuiPortRangeStart": 6080,
    "GuiPortRangeEnd": 6180
  }
}
