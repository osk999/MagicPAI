{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "ContextGathererWorkflow",
  "name": "Context Gatherer",
  "description": "Collect context in parallel: research, repo-map, and memory, then merge",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "context-gatherer-flow",
    "start": "research-context",
    "activities": [
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "research-context",
        "name": "Research Context"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "repo-map-context",
        "name": "Repo Map Context"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "memory-context",
        "name": "Memory Context"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "merge-context",
        "name": "Merge Context"
      }
    ],
    "connections": [
      { "source": { "activity": "research-context", "port": "Done" }, "target": { "activity": "merge-context" } },
      { "source": { "activity": "research-context", "port": "Failed" }, "target": { "activity": "merge-context" } },
      { "source": { "activity": "repo-map-context", "port": "Done" }, "target": { "activity": "merge-context" } },
      { "source": { "activity": "repo-map-context", "port": "Failed" }, "target": { "activity": "merge-context" } },
      { "source": { "activity": "memory-context", "port": "Done" }, "target": { "activity": "merge-context" } },
      { "source": { "activity": "memory-context", "port": "Failed" }, "target": { "activity": "merge-context" } }
    ]
  }
}
