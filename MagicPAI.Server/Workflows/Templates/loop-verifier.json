{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "LoopVerifierWorkflow",
  "name": "Loop Verifier",
  "description": "Generic execution loop: run agent, check completion, iterate until done or max attempts",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" },
    { "name": "Agent", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "sonnet" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "loop-verifier-flow",
    "start": "loop-runner",
    "activities": [
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "loop-runner",
        "name": "Loop Runner"
      },
      {
        "type": "MagicPAI.TriageActivity",
        "id": "loop-classifier",
        "name": "Loop Classifier"
      }
    ],
    "connections": [
      { "source": { "activity": "loop-runner", "port": "Done" }, "target": { "activity": "loop-classifier" } },
      { "source": { "activity": "loop-runner", "port": "Failed" }, "target": { "activity": "loop-classifier" } },
      { "source": { "activity": "loop-classifier", "port": "Complex" }, "target": { "activity": "loop-runner" } }
    ]
  }
}
