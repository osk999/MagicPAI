{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "VerifyAndRepairWorkflow",
  "name": "Verify and Repair",
  "description": "Run verification gates and auto-repair on failure",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "ContainerId", "typeName": "String", "value": "" },
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "AiAssistant", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "auto" },
    { "name": "WorkerOutput", "typeName": "String", "value": "" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "verify-repair-flow",
    "start": "initial-verify",
    "activities": [
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "initial-verify",
        "name": "Initial Verify"
      },
      {
        "type": "MagicPAI.RepairActivity",
        "id": "repair",
        "name": "Repair"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "repair-agent",
        "name": "Repair Agent"
      },
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "retry-verify",
        "name": "Retry Verify"
      }
    ],
    "connections": [
      { "source": { "activity": "initial-verify", "port": "Failed" }, "target": { "activity": "repair" } },
      { "source": { "activity": "repair", "port": "Done" }, "target": { "activity": "repair-agent" } },
      { "source": { "activity": "repair-agent", "port": "Done" }, "target": { "activity": "retry-verify" } },
      { "source": { "activity": "repair-agent", "port": "Failed" }, "target": { "activity": "retry-verify" } },
      { "source": { "activity": "retry-verify", "port": "Failed" }, "target": { "activity": "repair" } }
    ]
  }
}
