{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "OrchestrateSimplePathWorkflow",
  "name": "Orchestrate Simple Path",
  "description": "Single-agent execution with prompt assembly, context, and verification",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" },
    { "name": "AiAssistant", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "auto" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "orchestrate-simple-path-flow",
    "start": "assemble-prompt",
    "activities": [
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "assemble-prompt",
        "name": "Assemble Prompt"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "simple-execute",
        "name": "Simple Execute"
      },
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "simple-verify",
        "name": "Verify"
      }
    ],
    "connections": [
      { "source": { "activity": "assemble-prompt", "port": "Done" }, "target": { "activity": "simple-execute" } },
      { "source": { "activity": "assemble-prompt", "port": "Failed" }, "target": { "activity": "simple-execute" } },
      { "source": { "activity": "simple-execute", "port": "Done" }, "target": { "activity": "simple-verify" } }
    ]
  }
}
