{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "PromptGroundingWorkflow",
  "name": "Prompt Grounding",
  "description": "Analyze codebase and rewrite vague prompts into precise, file-specific instructions",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "prompt-grounding-flow",
    "start": "analyze-codebase",
    "activities": [
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "analyze-codebase",
        "name": "Analyze Codebase"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "rewrite-prompt",
        "name": "Rewrite Prompt"
      }
    ],
    "connections": [
      { "source": { "activity": "analyze-codebase", "port": "Done" }, "target": { "activity": "rewrite-prompt" } },
      { "source": { "activity": "analyze-codebase", "port": "Failed" }, "target": { "activity": "rewrite-prompt" } }
    ]
  }
}
