{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "FullOrchestrateWorkflow",
  "name": "Full Orchestrate",
  "description": "Complete AI orchestration: triage, agent execution, verification, and repair",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "WorkspacePath", "typeName": "String", "value": "/workspace" },
    { "name": "AiAssistant", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "auto" },
    { "name": "ContainerId", "typeName": "String", "value": "" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "full-orchestrate-flow",
    "start": "spawn-container",
    "activities": [
      {
        "type": "MagicPAI.SpawnContainerActivity",
        "id": "spawn-container",
        "name": "Spawn Container"
      },
      {
        "type": "MagicPAI.TriageActivity",
        "id": "triage",
        "name": "Triage"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "simple-agent",
        "name": "Simple Agent"
      },
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "simple-verify",
        "name": "Verify (Simple)"
      },
      {
        "type": "MagicPAI.ArchitectActivity",
        "id": "architect",
        "name": "Architect"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "complex-agent",
        "name": "Complex Agent"
      },
      {
        "type": "MagicPAI.RunVerificationActivity",
        "id": "complex-verify",
        "name": "Verify (Complex)"
      },
      {
        "type": "MagicPAI.RepairActivity",
        "id": "repair",
        "name": "Repair"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "repair-agent",
        "name": "Repair Agent"
      },
      {
        "type": "MagicPAI.DestroyContainerActivity",
        "id": "destroy-container",
        "name": "Destroy Container"
      }
    ],
    "connections": [
      { "source": { "activity": "spawn-container", "port": "Done" }, "target": { "activity": "triage" } },
      { "source": { "activity": "spawn-container", "port": "Failed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "triage", "port": "Simple" }, "target": { "activity": "simple-agent" } },
      { "source": { "activity": "triage", "port": "Complex" }, "target": { "activity": "architect" } },
      { "source": { "activity": "simple-agent", "port": "Done" }, "target": { "activity": "simple-verify" } },
      { "source": { "activity": "simple-agent", "port": "Failed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "simple-verify", "port": "Passed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "simple-verify", "port": "Failed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "simple-verify", "port": "Inconclusive" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "architect", "port": "Done" }, "target": { "activity": "complex-agent" } },
      { "source": { "activity": "architect", "port": "Failed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "complex-agent", "port": "Done" }, "target": { "activity": "complex-verify" } },
      { "source": { "activity": "complex-agent", "port": "Failed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "complex-verify", "port": "Passed" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "complex-verify", "port": "Inconclusive" }, "target": { "activity": "destroy-container" } },
      { "source": { "activity": "complex-verify", "port": "Failed" }, "target": { "activity": "repair" } },
      { "source": { "activity": "repair", "port": "Done" }, "target": { "activity": "repair-agent" } },
      { "source": { "activity": "repair-agent", "port": "Done" }, "target": { "activity": "complex-verify" } },
      { "source": { "activity": "repair-agent", "port": "Failed" }, "target": { "activity": "destroy-container" } }
    ]
  }
}
