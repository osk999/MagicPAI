{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "WebsiteAuditLoopWorkflow",
  "name": "Website Audit Loop",
  "description": "Four-phase autonomous website audit: discovery, visual, interaction, and Opus sweep",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "website-audit-loop-flow",
    "start": "phase1-discovery-runner",
    "activities": [
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "phase1-discovery-runner",
        "name": "Phase 1: Discovery Runner"
      },
      {
        "type": "MagicPAI.TriageActivity",
        "id": "phase1-discovery-check",
        "name": "Phase 1: Discovery Check"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "phase2-visual-runner",
        "name": "Phase 2: Visual Runner"
      },
      {
        "type": "MagicPAI.TriageActivity",
        "id": "phase2-visual-check",
        "name": "Phase 2: Visual Check"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "phase3-interaction-runner",
        "name": "Phase 3: Interaction Runner"
      },
      {
        "type": "MagicPAI.TriageActivity",
        "id": "phase3-interaction-check",
        "name": "Phase 3: Interaction Check"
      },
      {
        "type": "MagicPAI.AiAssistantActivity",
        "id": "phase4-opus-sweep",
        "name": "Phase 4: Opus Sweep"
      }
    ],
    "connections": [
      { "source": { "activity": "phase1-discovery-runner", "port": "Done" }, "target": { "activity": "phase1-discovery-check" } },
      { "source": { "activity": "phase1-discovery-runner", "port": "Failed" }, "target": { "activity": "phase1-discovery-check" } },
      { "source": { "activity": "phase1-discovery-check", "port": "Complex" }, "target": { "activity": "phase1-discovery-runner" } },
      { "source": { "activity": "phase1-discovery-check", "port": "Simple" }, "target": { "activity": "phase2-visual-runner" } },
      { "source": { "activity": "phase2-visual-runner", "port": "Done" }, "target": { "activity": "phase2-visual-check" } },
      { "source": { "activity": "phase2-visual-runner", "port": "Failed" }, "target": { "activity": "phase2-visual-check" } },
      { "source": { "activity": "phase2-visual-check", "port": "Complex" }, "target": { "activity": "phase2-visual-runner" } },
      { "source": { "activity": "phase2-visual-check", "port": "Simple" }, "target": { "activity": "phase3-interaction-runner" } },
      { "source": { "activity": "phase3-interaction-runner", "port": "Done" }, "target": { "activity": "phase3-interaction-check" } },
      { "source": { "activity": "phase3-interaction-runner", "port": "Failed" }, "target": { "activity": "phase3-interaction-check" } },
      { "source": { "activity": "phase3-interaction-check", "port": "Complex" }, "target": { "activity": "phase3-interaction-runner" } },
      { "source": { "activity": "phase3-interaction-check", "port": "Simple" }, "target": { "activity": "phase4-opus-sweep" } }
    ]
  }
}
