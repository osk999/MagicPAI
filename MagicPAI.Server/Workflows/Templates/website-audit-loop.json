{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "id": "",
  "definitionId": "WebsiteAuditLoopWorkflow",
  "name": "Website Audit Loop",
  "description": "Standalone website audit with container lifecycle and GUI-enabled browser execution",
  "createdAt": "0001-01-01T00:00:00+00:00",
  "version": 1,
  "variables": [
    { "id": "containerIdVariable", "name": "ContainerId", "typeName": "String", "isArray": false, "value": "" },
    { "id": "promptVariable", "name": "Prompt", "typeName": "String", "isArray": false, "value": "" },
    { "id": "aiAssistantVariable", "name": "AiAssistant", "typeName": "String", "isArray": false, "value": "claude" }
  ],
  "inputs": [],
  "outputs": [],
  "outcomes": [],
  "customProperties": {},
  "isReadonly": false,
  "isSystem": false,
  "isLatest": true,
  "isPublished": true,
  "options": { "autoUpdateConsumingWorkflows": false },
  "root": {
    "id": "website-audit-loop-flow",
    "nodeId": "Workflow1:website-audit-loop-flow",
    "type": "Elsa.Flowchart",
    "version": 1,
    "customProperties": { "source": "WebsiteAuditLoopWorkflow.cs" },
    "metadata": {},
    "activities": [
      {
        "workspacePath": { "typeName": "String", "expression": { "type": "Literal", "value": "" } },
        "enableGui": { "typeName": "Boolean", "expression": { "type": "Literal", "value": true } },
        "containerId": { "typeName": "String", "memoryReference": { "id": "containerIdVariable" } },
