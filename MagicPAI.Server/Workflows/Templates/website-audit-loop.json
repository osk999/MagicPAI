      { "id": "promptVariable", "name": "Prompt", "typeName": "String", "value": "" },
      { "id": "aiAssistantVariable", "name": "AiAssistant", "typeName": "String", "value": "claude" }
    ],
    "connections": [
      { "source": { "activity": "audit-spawn", "port": "Done" }, "target": { "activity": "audit-core" }, "vertices": [] },
      { "source": { "activity": "audit-spawn", "port": "Failed" }, "target": { "activity": "audit-destroy" }, "vertices": [] },
      { "source": { "activity": "audit-core", "port": "Done" }, "target": { "activity": "audit-destroy" }, "vertices": [] }
