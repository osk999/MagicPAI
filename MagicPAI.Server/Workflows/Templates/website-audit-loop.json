        "nodeId": "Workflow1:website-audit-loop-flow:audit-spawn",
        "name": null,
        "type": "MagicPAI.SpawnContainerActivity",
        "version": 1,
        "customProperties": {},
        "metadata": {}
      },
      {
        "workflowDefinitionId": { "typeName": "String", "expression": { "type": "Literal", "value": "WebsiteAuditCoreWorkflow" } },
        "waitForCompletion": { "typeName": "Boolean", "expression": { "type": "Literal", "value": true } },
        "input": {
          "typeName": "Object",
          "expression": {
            "type": "JavaScript",
            "value": "return { Prompt: getVariable('Prompt') || '', AiAssistant: getVariable('AiAssistant') || 'claude', ContainerId: getVariable('ContainerId') || '' };"
          }
        },
        "id": "audit-core",
        "nodeId": "Workflow1:website-audit-loop-flow:audit-core",
        "name": null,
        "type": "Elsa.ExecuteWorkflow",
