{
  "$schema": "https://elsaworkflows.io/schemas/3.x/workflow-definition.json",
  "definitionId": "ClawEvalAgentWorkflow",
  "name": "Claw Eval Agent",
  "description": "Benchmark agent workflow: triage, context-gathering, and agent execution for evaluation",
  "version": 1,
  "isLatest": true,
  "isPublished": true,
  "variables": [
    { "name": "Prompt", "typeName": "String", "value": "" },
    { "name": "ContainerId", "typeName": "String", "value": "" },
    { "name": "Agent", "typeName": "String", "value": "claude" },
    { "name": "Model", "typeName": "String", "value": "sonnet" }
  ],
  "root": {
    "type": "Elsa.Flowchart",
    "id": "claw-eval-agent-flow",
    "start": "eval-triage",
    "activities": [
      {
        "type": "MagicPAI.TriageActivity",
        "id": "eval-triage",
        "name": "Eval Triage"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "eval-context",
        "name": "Eval Context"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "eval-simple-exec",
        "name": "Eval Simple Execution"
      },
      {
        "type": "MagicPAI.RunCliAgentActivity",
        "id": "eval-complex-exec",
        "name": "Eval Complex Execution"
      }
    ],
    "connections": [
      { "source": { "activity": "eval-triage", "port": "Simple" }, "target": { "activity": "eval-context" } },
      { "source": { "activity": "eval-triage", "port": "Complex" }, "target": { "activity": "eval-context" } },
      { "source": { "activity": "eval-context", "port": "Done" }, "target": { "activity": "eval-simple-exec" } },
      { "source": { "activity": "eval-context", "port": "Failed" }, "target": { "activity": "eval-simple-exec" } }
    ]
  }
}
