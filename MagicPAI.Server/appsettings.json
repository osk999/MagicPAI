{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Elsa": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MagicPai": "Host=localhost;Port=5432;Database=magicpai;Username=magicpai;Password=magicpai"
  },
  "MagicPAI": {
    "UseDocker": true,
    "WorkerImage": "magicpai-env:latest",
    "DefaultAgent": "claude",
    "DefaultModel": "auto",
    "MaxTurnsPerTask": 20,
    "AgentTimeoutMinutes": 30,
    "EnableVerification": true,
    "EnableRepair": true,
    "MaxRepairAttempts": 5,
    "DefaultGates": [ "compile", "test", "hallucination" ],
    "CoverageThreshold": 70.0,
    "MaxBudgetUsd": 0,
    "BudgetLimitEnabled": false,
    "TrackCosts": true,
    "ComplexityThreshold": 5,
    "MaxSubTasks": 10,
    "MaxParallelWorkers": 3,
    "EnableSignalR": true,
    "SignalRBufferSize": 1000,
    "WorkspacePath": "",
    "ContainerWorkDir": "/workspace"
  },
  "Elsa": {
    "Identity": {
      "SigningKey": "sufficiently-long-secret-key-for-development-only-replace-in-production"
    }
  }
}
