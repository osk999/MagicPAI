{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MagicPai": "Data Source=magicpai.db"
  },
  "MagicPAI": {
    "UseDocker": true,
    "WorkerImage": "magicpai-env:latest",
    "DefaultAgent": "claude",
    "DefaultModel": "auto",
    "MaxTurnsPerTask": 20,
    "AgentTimeoutMinutes": 30,
    "EnableVerification": true,
    "EnableRepair": true,
    "MaxRepairAttempts": 5,
    "DefaultGates": [ "compile", "test", "hallucination" ],
    "CoverageThreshold": 70.0,
    "MaxBudgetUsd": 0,
    "BudgetLimitEnabled": false,
    "TrackCosts": true,
    "ComplexityThreshold": 5,
    "MaxSubTasks": 10,
    "MaxParallelWorkers": 3,
    "EnableSignalR": true,
    "SignalRBufferSize": 1000,
    "WorkspacePath": "C:\\Users\\PC\\AppData\\Local\\Temp\\magicpai-workspace",
    "ContainerWorkDir": "/workspace",
    "EnableContainerGui": true,
    "GuiPortRangeStart": 6080,
    "GuiPortRangeEnd": 6180,
    "AuthServiceUrl": "",
    "AuthDefaultEmail": "",
    "AuthApiKey": ""
  },
  "Temporal": {
    "Host": "localhost:7233",
    "Namespace": "magicpai",
    "TaskQueue": "magicpai-main",
    "UiBaseUrl": "http://localhost:8233"
  }
}
